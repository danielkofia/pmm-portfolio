{
  "version": 2,
  "name": "daniel-kofi-agyei-portfolio",
  "builds": [
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/cv", "dest": "/daniel-kofi-agyei-cv.pdf" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/daniel-kofi-agyei-cv.pdf",
      "headers": [
        { "key": "Content-Type", "value": "application/pdf" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"Daniel-Kofi-Agyei-CV.pdf\"" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
